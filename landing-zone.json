{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.45.15.27210",
      "templateHash": "4924669156434553269"
    }
  },
  "parameters": {
    "managedIdentityPrincipalId": {
      "type": "string",
      "metadata": {
        "description": "Principal id of Frugal's user-assigned managed identity (managedIdentityPrincipalId output from the main install)."
      }
    },
    "avdResourceGroupName": {
      "type": "string",
      "defaultValue": "rg-frugal-avd",
      "metadata": {
        "description": "Resource group Frugal will provision AVD into within THIS landing-zone subscription."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[deployment().location]",
      "metadata": {
        "description": "Location for the resource group + FSLogix storage + gallery."
      }
    },
    "fslogixStorageAccount": {
      "type": "string",
      "metadata": {
        "description": "Globally-unique name for this subscription's FSLogix profile storage account."
      }
    },
    "galleryName": {
      "type": "string",
      "defaultValue": "frugalGallery",
      "metadata": {
        "description": "Compute Gallery name (golden images captured in this subscription)."
      }
    },
    "imageDefinitionName": {
      "type": "string",
      "defaultValue": "win11-avd-custom",
      "metadata": {
        "description": "Image definition name in the gallery."
      }
    }
  },
  "variables": {
    "readerRoleId": "acdd72a7-3385-48ef-bd42-f606fba81ae7",
    "cmReaderRoleId": "72fafb9e-0641-4937-9268-a91bfd8191a3"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2024-11-01",
      "name": "[parameters('avdResourceGroupName')]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, parameters('managedIdentityPrincipalId'), variables('readerRoleId'))]",
      "properties": {
        "principalId": "[parameters('managedIdentityPrincipalId')]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('readerRoleId'))]"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, parameters('managedIdentityPrincipalId'), variables('cmReaderRoleId'))]",
      "properties": {
        "principalId": "[parameters('managedIdentityPrincipalId')]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('cmReaderRoleId'))]"
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "lz-avd-rbac",
      "resourceGroup": "[parameters('avdResourceGroupName')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "principalId": {
            "value": "[parameters('managedIdentityPrincipalId')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "fslogixStorageAccount": {
            "value": "[parameters('fslogixStorageAccount')]"
          },
          "galleryName": {
            "value": "[parameters('galleryName')]"
          },
          "imageDefinitionName": {
            "value": "[parameters('imageDefinitionName')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.45.15.27210",
              "templateHash": "10069070607291842053"
            }
          },
          "parameters": {
            "principalId": {
              "type": "string",
              "metadata": {
                "description": "Principal id of Frugal's user-assigned managed identity."
              }
            },
            "location": {
              "type": "string",
              "defaultValue": "[resourceGroup().location]",
              "metadata": {
                "description": "Location for the FSLogix storage account."
              }
            },
            "fslogixStorageAccount": {
              "type": "string",
              "metadata": {
                "description": "Globally-unique name for the FSLogix profile storage account."
              }
            },
            "galleryName": {
              "type": "string",
              "defaultValue": "frugalGallery",
              "metadata": {
                "description": "Compute Gallery name (golden images are captured here)."
              }
            },
            "imageDefinitionName": {
              "type": "string",
              "defaultValue": "win11-avd-custom",
              "metadata": {
                "description": "Image definition name in the gallery."
              }
            }
          },
          "variables": {
            "contributorRoleId": "b24988ac-6180-42a0-ab88-20f7382dd24c",
            "rbacAdminRoleId": "f58310d9-a9f6-439a-9e8d-f62e7b41a168",
            "desktopVirtUserRoleId": "1d18fff3-a72a-46b5-b4a9-0b38a3cd7e63",
            "vmUserLoginRoleId": "fb879df8-f326-4884-b1cf-06f3ad86be52",
            "smbShareContribRoleId": "0c867c2a-1d8c-454a-a3db-ab2ea1bdc8bb",
            "allowedRoles": "[format('{{{0}, {1}, {2}}}', variables('desktopVirtUserRoleId'), variables('vmUserLoginRoleId'), variables('smbShareContribRoleId'))]"
          },
          "resources": [
            {
              "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
              "apiVersion": "2023-05-01",
              "name": "[format('{0}/{1}/{2}', parameters('fslogixStorageAccount'), 'default', 'profiles')]",
              "properties": {
                "shareQuota": 100,
                "enabledProtocols": "SMB"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/fileServices', parameters('fslogixStorageAccount'), 'default')]"
              ]
            },
            {
              "type": "Microsoft.Storage/storageAccounts/fileServices",
              "apiVersion": "2023-05-01",
              "name": "[format('{0}/{1}', parameters('fslogixStorageAccount'), 'default')]",
              "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', parameters('fslogixStorageAccount'))]"
              ]
            },
            {
              "type": "Microsoft.Storage/storageAccounts",
              "apiVersion": "2023-05-01",
              "name": "[parameters('fslogixStorageAccount')]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "Standard_LRS"
              },
              "kind": "StorageV2",
              "properties": {
                "minimumTlsVersion": "TLS1_2",
                "allowBlobPublicAccess": false,
                "azureFilesIdentityBasedAuthentication": {
                  "directoryServiceOptions": "AADKERB"
                }
              }
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "name": "[guid(resourceGroup().id, parameters('principalId'), variables('contributorRoleId'))]",
              "properties": {
                "principalId": "[parameters('principalId')]",
                "principalType": "ServicePrincipal",
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('contributorRoleId'))]"
              }
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "name": "[guid(resourceGroup().id, parameters('principalId'), variables('rbacAdminRoleId'))]",
              "properties": {
                "principalId": "[parameters('principalId')]",
                "principalType": "ServicePrincipal",
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('rbacAdminRoleId'))]",
                "conditionVersion": "2.0",
                "condition": "[format('((!(ActionMatches{{''Microsoft.Authorization/roleAssignments/write''}})) OR (@Request[Microsoft.Authorization/roleAssignments:RoleDefinitionId] ForAnyOfAnyValues:GuidEquals {0})) AND ((!(ActionMatches{{''Microsoft.Authorization/roleAssignments/delete''}})) OR (@Resource[Microsoft.Authorization/roleAssignments:RoleDefinitionId] ForAnyOfAnyValues:GuidEquals {1}))', variables('allowedRoles'), variables('allowedRoles'))]"
              }
            },
            {
              "type": "Microsoft.Compute/galleries",
              "apiVersion": "2023-07-03",
              "name": "[parameters('galleryName')]",
              "location": "[parameters('location')]",
              "properties": {
                "description": "Frugal golden images"
              }
            },
            {
              "type": "Microsoft.Compute/galleries/images",
              "apiVersion": "2023-07-03",
              "name": "[format('{0}/{1}', parameters('galleryName'), parameters('imageDefinitionName'))]",
              "location": "[parameters('location')]",
              "properties": {
                "osType": "Windows",
                "osState": "Generalized",
                "hyperVGeneration": "V2",
                "identifier": {
                  "publisher": "Frugal",
                  "offer": "AVD",
                  "sku": "win11-avd-custom"
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.Compute/galleries', parameters('galleryName'))]"
              ]
            }
          ],
          "outputs": {
            "fslogixStorageAccount": {
              "type": "string",
              "value": "[parameters('fslogixStorageAccount')]"
            },
            "galleryName": {
              "type": "string",
              "value": "[parameters('galleryName')]"
            },
            "imageDefinitionName": {
              "type": "string",
              "value": "[parameters('imageDefinitionName')]"
            }
          }
        }
      },
      "dependsOn": [
        "[subscriptionResourceId('Microsoft.Resources/resourceGroups', parameters('avdResourceGroupName'))]"
      ]
    }
  ],
  "outputs": {
    "avdResourceGroupName": {
      "type": "string",
      "value": "[parameters('avdResourceGroupName')]"
    },
    "fslogixStorageAccount": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('avdResourceGroupName')), 'Microsoft.Resources/deployments', 'lz-avd-rbac'), '2025-04-01').outputs.fslogixStorageAccount.value]"
    },
    "galleryName": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('avdResourceGroupName')), 'Microsoft.Resources/deployments', 'lz-avd-rbac'), '2025-04-01').outputs.galleryName.value]"
    },
    "nextStep": {
      "type": "string",
      "value": "[format('In Frugal: Subscriptions -> Discover, enable subscription {0}, then pick it when creating a host pool.', subscription().subscriptionId)]"
    }
  }
}