      "metadata": {
        "description": "Deployment location. Defaults to the deployment metadata location (the --location passed to the deploy command), so customers only specify the region once."
      }
    },
    "resourceGroupName": {
      "type": "string",
      "defaultValue": "rg-frugal",
      "metadata": {
        "description": "Resource group to create / use."
      }
