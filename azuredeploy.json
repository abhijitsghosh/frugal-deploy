    "dbAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "PostgreSQL admin password (12+ chars, mixed)."
      }
    },
    "entraTenantId": {
      "type": "string",
      "defaultValue": "[subscription().tenantId]",
      "metadata": {
        "description": "Microsoft Entra tenant id that issues access tokens. Defaults to the deploying subscription's tenant."
      }
    },
    "entraApiClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Client id (appId) of the Entra app registration created by auth.bicep (step 1). When empty, the app deploys with sign-in disabled — evaluation only."
      }
    },
    "resourceNameSuffix": {
      "type": "string",
      "defaultValue": "[utcNow('yyMMddHHmmss')]",
      "metadata": {
        "description": "Suffix appended to globally-unique resource names (Key Vault, PostgreSQL). Defaults to a deploy-time timestamp so a redeploy after teardown never collides with a soft-deleted name. Override with a fixed value to keep names stable across redeploys of the same environment."
      }
    },
    "avdResourceGroupName": {
      "type": "string",
      "defaultValue": "rg-frugal-avd",
      "metadata": {
        "description": "Resource group Frugal provisions AVD into (host pools + session-host VMs). Kept separate from Frugal's own infra so its broad permissions are scoped to one group."
      }
    }
  },
