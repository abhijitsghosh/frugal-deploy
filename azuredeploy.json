      "type": "string",
      "metadata": {
        "description": "Container image, e.g. ghcr.io/abhijitsghosh/frugal:0.1.0"
      }
    },
    "dbAdminUser": {
      "type": "string",
      "defaultValue": "frugaladmin",
      "metadata": {
        "description": "PostgreSQL admin username."
      }
